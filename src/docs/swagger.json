      "get": {
        "tags": ["Cars"],
        "summary": "Get car reviews",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "carId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
